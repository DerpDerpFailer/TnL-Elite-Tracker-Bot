# Copy this file to `.env` for local runs outside Portainer.
# In production (Portainer), these are set in the Stack's "Environment variables" section instead —
# never commit a real token to this repository.

# Discord bot token from the Discord Developer Portal (Bot tab).
DISCORD_TOKEN=your-bot-token-here

# ID of the single guild (server) this bot serves. Used to sync slash commands instantly to that guild.
GUILD_ID=123456789012345678

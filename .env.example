# Copy this file to `.env` for local runs outside Portainer.
# In production (Portainer), these are set in the Stack's "Environment variables" section instead —
# never commit a real token to this repository.

# Discord bot token from the Discord Developer Portal (Bot tab).
DISCORD_TOKEN=your-bot-token-here

# ID of the "owner" server: the one allowed to edit shared settings (zones,
# cooldowns, maps, fallback/found-watch) — see the README's "Multi-server
# installs" section. The bot can be invited to any number of other servers
# too; each one just configures its own channel/roles via /elite-config.
OWNER_GUILD_ID=123456789012345678
